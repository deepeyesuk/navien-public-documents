---
const pageTitle = "Navien Public Documents";

// Get all pages dynamically
const pages = await Astro.glob('./*.md');
const pageLinks = pages.map(page => ({
  url: page.url,
  title: page.frontmatter?.title || page.url?.split('/').pop()?.replace('.md', '') || 'Untitled',
  description: page.frontmatter?.description || '',
  icon: page.frontmatter?.icon || '📄'
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        line-height: 1.6;
        background: #e8e8e8;
        color: #1a1a1a;
      }
      .header {
        background: white;
        border-bottom: 1px solid #e0e0e0;
        padding: 0 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }
      .logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.25rem;
        color: #1a1a1a;
        text-decoration: none;
      }
      .logo-icon {
        font-weight: bold;
        font-size: 1.5rem;
        color: #4a90e2;
      }
      .logo-text {
        font-weight: 600;
      }
      .logo-subtitle {
        font-weight: 400;
        color: #666;
      }
      .nav {
        display: flex;
        gap: 2rem;
        align-items: center;
      }
      .nav a {
        color: #666;
        text-decoration: none;
        font-size: 1rem;
      }
      .nav a.active {
        color: #1a1a1a;
        border-bottom: 2px solid #4a90e2;
        padding-bottom: 1.5rem;
      }
      .search-box {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border: 1px solid #e0e0e0;
        border-radius: 24px;
        background: #f5f5f5;
        min-width: 200px;
      }
      .search-icon {
        color: #999;
      }
      .search-box input {
        border: none;
        background: transparent;
        outline: none;
        color: #666;
      }
      .breadcrumb {
        background: white;
        padding: 1rem 2rem;
        border-bottom: 1px solid #e0e0e0;
        display: flex;
        gap: 0.5rem;
        align-items: center;
        font-size: 0.95rem;
      }
      .breadcrumb a {
        color: #666;
        text-decoration: none;
      }
      .breadcrumb a:hover {
        color: #4a90e2;
      }
      .breadcrumb span {
        color: #999;
      }
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 3rem 2rem;
      }
      h1 {
        color: #1a1a1a;
        font-size: 2.5rem;
        margin-bottom: 1rem;
        font-weight: 700;
      }
      .subtitle {
        color: #666;
        font-size: 1.125rem;
        margin-bottom: 3rem;
      }
      .page-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .page-card {
        background: white;
        border: 1px solid #e0e0e0;
        border-radius: 12px;
        padding: 1.5rem;
        display: flex;
        align-items: flex-start;
        gap: 1.25rem;
        text-decoration: none;
        color: inherit;
        transition: all 0.2s;
      }
      .page-card:hover {
        border-color: #4a90e2;
        box-shadow: 0 4px 12px rgba(74, 144, 226, 0.15);
        transform: translateY(-2px);
      }
      .page-icon {
        width: 56px;
        height: 56px;
        background: #e8f2fc;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        flex-shrink: 0;
      }
      .page-content {
        flex: 1;
      }
      .page-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: #1a1a1a;
        margin-bottom: 0.25rem;
      }
      .page-description {
        color: #666;
        font-size: 0.95rem;
      }
    </style>
  </head>
  <body>
    <header class="header">
      <a href="/navien-public-documents" class="logo">
        <span class="logo-icon">N</span>
        <span class="logo-text">Navien</span>
        <span class="logo-subtitle">Public Documents</span>
      </a>
      <nav class="nav">
        <a href="/navien-public-documents" class="active">Docs</a>
        <a href="#">API</a>
        <a href="#">Support</a>
      </nav>
      <div class="search-box">
        <span class="search-icon">🔍</span>
        <input type="text" placeholder="Search" />
      </div>
    </header>
    <div class="breadcrumb">
      <a href="/navien-public-documents">Home</a>
      <span>›</span>
      <a href="#">Navien</a>
      <span>›</span>
      <span>Docs</span>
    </div>
    <div class="container">
      <h1>Available Pages</h1>
      <p class="subtitle">Welcome to the Navien Public Documents site. Explore our comprehensive resources and guides.</p>
      <div class="page-list">
        <a href="/navien-public-documents" class="page-card">
          <div class="page-icon">🏠</div>
          <div class="page-content">
            <div class="page-title">Home</div>
            <div class="page-description">The main landing page for all public documentation.</div>
          </div>
        </a>
        {pageLinks.map(page => (
          <a href={page.url} class="page-card">
            <div class="page-icon">{page.icon}</div>
            <div class="page-content">
              <div class="page-title">{page.title}</div>
              <div class="page-description">{page.description}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </body>
</html>

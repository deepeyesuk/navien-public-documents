---
const pageTitle = "Navien Public Documents";

// Get all pages dynamically
const pages = await Astro.glob('./*.md');
const pageLinks = pages.map(page => ({
  url: page.url,
  title: page.frontmatter?.title || page.url?.split('/').pop()?.replace('.md', '') || 'Untitled'
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <style>
      body {
        font-family: system-ui, -apple-system, sans-serif;
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
        line-height: 1.6;
      }
      h1 {
        color: #333;
        margin-top: 0;
      }
      ul {
        list-style: none;
        padding: 0;
      }
      li {
        margin: 1rem 0;
      }
      a {
        color: #0066cc;
        text-decoration: none;
        font-size: 1.125rem;
      }
      a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <h1>Available Pages</h1>
    <p>Welcome to the Navien Public Documents site.</p>
    <ul>
      <li><a href="/navien-public-documents">Home</a></li>
      {pageLinks.map(page => (
        <li><a href={page.url}>{page.title}</a></li>
      ))}
    </ul>
  </body>
</html>
